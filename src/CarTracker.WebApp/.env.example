# Auth0 configuration for the interactive login (README §6).
#
# None of these are secrets — copy this file to `.env` only to point the app at a DIFFERENT Auth0 tenant. Left
# unset, the app falls back to this project's tenant (see src/lib/authConfig.ts), so a local run needs no .env.
#
# These MUST match the API's Auth0:Authority / Auth0:Audience (src/CarTracker.WebApi/appsettings.json):
#   VITE_AUTH0_DOMAIN   -> the Authority without scheme/trailing slash
#   VITE_AUTH0_AUDIENCE -> the API identifier the SPA requests a token for (makes the token a verifiable JWT)
#
# Also register the browser origin (the GATEWAY, e.g. http://localhost:5080 in dev, and your prod origin) in
# the Auth0 application's Allowed Callback URLs, Logout URLs and Web Origins, and enable refresh token rotation.

VITE_AUTH0_DOMAIN=usualexpat.uk.auth0.com
VITE_AUTH0_CLIENT_ID=AYVXSt9aa5rz4kHFYs3KZ5HqYfBNkPKp
VITE_AUTH0_AUDIENCE=cartracker.api
