{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    // "node" is here for the test files under src/ that read the token layer off disk (styles/tokens.test.ts).
    // Application code has no business importing node built-ins; `oxlint` is the guard on that, not tsc.
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom", "node"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    /* Per the TSX decision in docs/specs/2026-07-14-react-app-foundation. The derived-metrics service
       returns figures that are legitimately null (mpg on a first fill, percentUsed on a zero budget), and
       each null means something the UI must say out loud. exactOptionalPropertyTypes keeps "absent" and
       "present and null" apart — the difference between a bug and a real state. */
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["src"]
}
